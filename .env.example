# Copy this file to `.env` and fill in your Supabase project values.
# The game runs fully OFFLINE without these — they only enable cloud content
# hot-loading, anonymous auth, cloud saves, and (later) the shared-dead universe.

# Browser-safe (anon) key — Vite exposes VITE_-prefixed vars to the client.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Service-role key — NEVER commit this or expose it to the browser.
# Used only by the seed script (supabase/seed.mjs) to write content_* tables.
# Set it inline when seeding instead of storing it here if you prefer:
#   SUPABASE_URL=... SUPABASE_SERVICE_KEY=... npm run seed
# SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# SUPABASE_SERVICE_KEY=your-service-role-key
