{
  "name": "kestrel-run",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "lint:rng": "node scripts/check-rng.mjs",
    "lint:content": "node scripts/check-content.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "ci": "npm run lint:rng && npm run lint:content && npm run typecheck && npm run test && vite build && node scripts/check-bundle.mjs",
    "build": "npm run lint:rng && npm run lint:content && tsc --noEmit && vite build",
    "preview": "vite preview",
    "seed": "node supabase/seed.mjs",
    "meshy:list": "node --env-file=.env scripts/meshy/list.mjs",
    "meshy:generate": "node --env-file=.env scripts/meshy/generate.mjs",
    "meshy:download": "node --env-file=.env scripts/meshy/download.mjs",
    "meshy:batch": "node --env-file=.env scripts/meshy/generate-batch.mjs",
    "meshy:shrink": "node scripts/meshy/shrink-models.mjs"
  },
  "devDependencies": {
    "@types/three": "^0.185.1",
    "jsdom": "^29.1.1",
    "sharp": "^0.35.3",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.2",
    "three": "^0.185.1"
  }
}
